# WhatsApp Cloud API
WA_TOKEN=your_whatsapp_access_token
WA_PHONE_ID=your_phone_number_id
WA_VERIFY_TOKEN=salonbot_verify_123

# Supabase
SUPABASE_URL=https://xxxx.supabase.co
# POMEMBNO: uporabi SERVICE_ROLE (secret) kljuc, NE anon kljuca.
# Streznik je zaupanja vreden backend in mora obiti RLS, da bere vse salone/rezervacije.
# Anon kljuc z vklopljenim RLS vrne prazno (dashboard pokaze 0 salonov).
SUPABASE_KEY=your_supabase_service_role_key

# Server
PORT=3000
# Nastavi eksplicitno, da seje niso vezane na SUPABASE_KEY (sicer ob menjavi kljuca odjavi vse).
SESSION_SECRET=change_me_to_a_long_random_string
ADMIN_API_KEY=change_me
MASTER_ADMIN_PHONES=386xxxxxxxx

# Email fallback for booking notifications when a salon has no admin_phone
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=FlowTiq <noreply@yourdomain.com>

# Base URL for confirm/cancel links in admin emails (set to your Railway domain)
BASE_URL=https://your-railway-app.railway.app

# ─── Stripe (naročnine) ─────────────────────────────────────
# 1. Skrivni ključ: Stripe Dashboard -> Developers -> API keys
STRIPE_SECRET_KEY=sk_live_xxx
# 2. Webhook signing secret: Developers -> Webhooks -> endpoint https://TVOJA-DOMENA/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_xxx
# 3. Price ID-ja paketov: Products -> (izdelek) -> Pricing -> API ID (price_...)
STRIPE_PRICE_STARTER=price_xxx_starter_4999
STRIPE_PRICE_PRO=price_xxx_pro_7999
STRIPE_PRICE_AI=price_xxx_ai_15999

# AI natakar (paket AI)
# Ponudnik: 'openai', 'anthropic' (Claude) ali 'gemini' (Google)
AI_PROVIDER=gemini
ANTHROPIC_API_KEY=sk-ant-xxx
GEMINI_API_KEY=AIza-xxx
# Model: anthropic -> claude-haiku-4-5 · gemini -> gemini-2.5-flash · openai -> gpt-4o-mini / gpt-4o
AI_ORDER_MODEL=gemini-2.5-flash
# Fair-use meja standardnega AI paketa (naročil/mesec); Enterprise (cena po meri) je brez omejitve
AI_FAIR_USE_LIMIT=1500
